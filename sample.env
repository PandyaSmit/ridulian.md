# ==========================================
# ridulian.md - Environment Configuration
# ==========================================

# ------------------------------------------
# Authentication (NextAuth / Auth.js)
# ------------------------------------------

# Must be defined for production JWT encryption securely.
# Generate via: openssl rand -base64 32
NEXTAUTH_SECRET="your_super_secret_string"

# Base URL of the application. Required by NextAuth.
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth App Credentials
GITHUB_ID="your_github_oauth_client_id"
GITHUB_SECRET="your_github_oauth_client_secret"

# ------------------------------------------
# Open-Core Storage Layer
# ------------------------------------------

# Set to "LOCAL" to use the file system (`content/` directory).
# Set to "CLOUD" to enable multi-tenant architecture using AWS S3.
STORAGE_MODE="LOCAL"

# If STORAGE_MODE="CLOUD", define these AWS S3 parameters:
AWS_REGION="us-east-1"
S3_BUCKET_NAME="ridulian-lore-bucket"

# Security Credentials required by S3Client if storage mode "CLOUD" 
AWS_ACCESS_KEY_ID="your_aws_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret"
